# Supabase — für Login/Registrierung & Mitgliederbereich.
# Diese Werte in Vercel unter Settings → Environment Variables eintragen.
# Den "publishable"/anon Key findest du in Supabase unter Project Settings → API.
VITE_SUPABASE_URL=https://DEIN-PROJEKT.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx

# Optional — Shopify (sonst werden die Standardwerte aus dem Code genutzt)
# VITE_SHOPIFY_DOMAIN=deinshop.myshopify.com
# VITE_SHOPIFY_STOREFRONT_TOKEN=xxxxxxxxxxxxxxxx
